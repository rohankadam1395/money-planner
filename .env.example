# ============================================
# Money Planner - Environment Configuration
# ============================================
#
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control
#
# Development (.env.local)
# Production (.env.prod)

# Database Configuration
# =====================
DB_USER=postgres
DB_PASSWORD=your-secure-password-here
DB_NAME=money_planner
DB_PORT=5432

# Backend API Configuration
# =========================
API_PORT=8080
LOG_LEVEL=info

# Security Configuration
# ======================
# Generate a strong JWT secret: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here-change-in-production

# API Configuration
# =================
API_URL=http://localhost:8080

# Frontend Configuration
# ======================
NEXT_PUBLIC_API_URL=http://localhost:8080
FRONTEND_PORT=3000

# CORS Configuration
# ==================
CORS_ORIGIN=http://localhost:3000

# Logging Configuration
# ====================
# Options: debug, info, warn, error
LOG_LEVEL=info

# Database Connection Pooling
# ===========================
# Max number of database connections
DB_MAX_CONNECTIONS=20
DB_IDLE_CONNECTIONS=5
DB_CONNECTION_TIMEOUT=5s

# Feature Flags (for future use)
# ==============================
# FEATURE_MULTI_BANK_ENABLED=true
# FEATURE_DUPLICATE_DETECTION_ENABLED=true
