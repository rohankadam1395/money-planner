# Database Configuration
# For local development, use sslmode=disable
# For production, change to sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/money_planner?sslmode=disable

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# Server Port (optional, defaults to 8080)
PORT=8080

# Merchant Dictionary Configuration
# Cache size for merchant lookups (default: 10000)
MERCHANTS_CACHE_SIZE=10000

# Fuzzy match threshold for merchant name matching (0.0-1.0, default: 0.85)
MERCHANTS_FUZZY_THRESHOLD=0.85

# LLM Provider Configuration for Unknown Merchant Categorization
# Options: ollama, claude, or leave empty to disable LLM categorization
LLM_PROVIDER=ollama

# Ollama Configuration (if LLM_PROVIDER=ollama)
# URL where Ollama service is running
OLLAMA_URL=http://localhost:11434
# Ollama model to use (default: mistral)
OLLAMA_MODEL=mistral

# Claude API Configuration (if LLM_PROVIDER=claude)
# Your Anthropic API key for Claude categorization
ANTHROPIC_API_KEY=sk-your-api-key-here
